# Gemini API key. The server checks GEMINI_API_KEY first, then GOOGLE_API_KEY.
GEMINI_API_KEY=
GOOGLE_API_KEY=

# Gemini model to use for question planning.
GEMINI_MODEL=gemini-2.5-flash

# SEC requests work best with a descriptive user agent that includes contact info.
SEC_USER_AGENT=Your Name your.email@example.com
